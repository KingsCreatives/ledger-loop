generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  ASSETS
  LIABILITIES
  EQUITY
  REVENUE
  EXPENSE
 }

enum LineType {
  DEBIT
  CREDIT
}

model User {
 id  String @id @default(uuid())
 email String @unique
 accounts Account[]
 createdAt DateTime @default(now())
}

model Account {
 id  String @id @default(uuid())
 name String
 type AccountType
 user   User  @relation(fields: [userId], references: [id])
 userId String  
 lines TransactionLine[]
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}

model JournalEntry{
  id String @id @default(uuid())
  date DateTime 
  description String
  lines TransactionLine []
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionLine{
  id String @id @default(uuid())
  amount Int
  type LineType
  journalEntryLine JournalEntry @relation(fields: [journalEntryId], references: [id])
  journalEntryId String
  accountEntry Account @relation(fields: [accountId], references: [id])
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}